{
    "name": "paolorox/ti-ext-whatsapp-selfhost",
    "type": "tastyigniter-package",
    "description": "WhatsApp integration for TastyIgniter via OpenWA self-hosted API. Send automated WhatsApp messages on order and reservation events.",
    "license": "MIT",
    "authors": [
        {
            "name": "Paolo Rossini",
            "email": "tipaolorossiniweb@gmail.com"
        }
    ],
    "require": {
        "tastyigniter/core": "^4.0",
        "tastyigniter/ti-ext-automation": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Igniter\\Whatsapp\\": "src/"
        }
    },
    "extra": {
        "tastyigniter-extension": {
            "code": "igniter.whatsapp",
            "name": "WhatsApp Integration",
            "icon": {
                "class": "fab fa-whatsapp",
                "backgroundColor": "#25D366",
                "color": "#FFF"
            },
            "homepage": "https://github.com/Paolorox/ti-ext-whatsapp-selfhost"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}